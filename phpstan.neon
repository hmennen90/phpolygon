parameters:
    level: 10
    # php-glfw fires PHP closures synchronously during glfwSetWindowMonitor,
    # corrupting zvals at runtime. Guards like is_array() on PHPDoc-typed values
    # are intentional defensive checks — PHPDoc types are not always reliable.
    treatPhpDocTypesAsCertain: false
    paths:
        - src
    excludePaths:
        - src/Rendering/VulkanRenderer3D.php
    scanFiles:
        - stubs/vulkan.stub.php
        - stubs/metal.stub.php
        - stubs/glfw.stub.php
    ignoreErrors:
        -
            identifier: trait.unused
            path: src/Testing/VisualTestCase.php
